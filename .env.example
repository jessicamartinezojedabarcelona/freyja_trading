# Copia este archivo a .env y completa todos los valores obligatorios.
# .env está ignorado por Git; nunca se debe versionar ni compartir.
# Obligatorio: nombre local de la base de datos.
POSTGRES_DB=
# Obligatorio: usuario local de PostgreSQL.
POSTGRES_USER=
# Obligatorio: contraseña local robusta y exclusiva para desarrollo.
POSTGRES_PASSWORD=
# Opcional: puerto local; 5432 por defecto.
POSTGRES_PORT=5432

# Obligatorio: entorno de ejecución explícito. No es un secreto; sin valor
# por defecto en el código. Usa "development" en local, "test" en pruebas/CI,
# "production" únicamente en un despliegue real (exige configuración SMTP y
# de rate limiting adicional — ver README).
FREYJA_ENVIRONMENT=development

# Correo en desarrollo: apunta al servicio local aislado Mailpit
# (docker compose --profile dev up mailpit), que nunca envía nada fuera de
# tu máquina. Sin credenciales, sin TLS: solo válido para 127.0.0.1.
FREYJA_SMTP_HOST=127.0.0.1
FREYJA_SMTP_PORT=1025
FREYJA_SMTP_USE_TLS=false
FREYJA_SMTP_FROM_ADDRESS=dev@freyja.local

# Opcional en desarrollo/test (se genera una clave efímera si se omite).
# Obligatorio y secreto real en producción; nunca lo versiones.
FREYJA_RATE_LIMIT_HMAC_KEY=

# Origen exacto permitido para CORS con credenciales. No es un secreto, pero
# en producción no puede quedar en el valor de desarrollo (localhost:4200):
# debe ser la URL pública real del frontend.
FREYJA_FRONTEND_ORIGIN=http://localhost:4200

# Lista separada por comas de hosts permitidos en la cabecera Host (rechaza
# el resto con 400). En producción no puede quedar en el valor de desarrollo.
FREYJA_ALLOWED_HOSTS=localhost,127.0.0.1
